# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
MANIFEST

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── uv ──────────────────────────────────────────────────────────
